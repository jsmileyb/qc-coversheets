# Copy this file to .env and fill in real values.
# Test mode settings for developer testing and local development. Do not use in production.
TEST_MODE=true

# App settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
INGEST_MODE=sync
INGEST_CONCURRENCY_LIMIT=20

# ERP -> App auth (required)
ERP_HMAC_SECRET=replace-with-long-random-secret

# App -> ERP fetch
ERP_FETCH_BASE_URL=https://vp.greshamsmith.com/vantagepoint/api

# ERP token endpoint (password grant flow)
ERP_TOKEN_URL=https://vp.greshamsmith.com/vantagepoint/api/token
ERP_USERNAME=your-username
ERP_PASSWORD=your-password
ERP_GRANT_TYPE=password
ERP_INTEGRATED=N
ERP_DATABASE=Vantagepoint
ERP_CLIENT_ID=your-client-id
ERP_CLIENT_SECRET=your-client-secret
ERP_REFRESH_TOKEN=your-refresh-token
ERP_SCOPE=

# InvokeCustom stored procedure
ERP_STORED_PROCEDURE=your_stored_procedure_name
