# Copy this file to .env and fill in real values.
# Test mode settings for developer testing and local development. Do not use in production.
TEST_MODE=true

# App settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
INGEST_MODE=sync
INGEST_CONCURRENCY_LIMIT=20
ENVIRONMENT_NAME=local

# ERP -> App auth (required)
ERP_HMAC_SECRET=replace-with-long-random-secret

# App -> ERP fetch
ERP_FETCH_BASE_URL=https://vp.greshamsmith.com/vantagepoint/api

# ERP token endpoint (password grant flow)
ERP_TOKEN_URL=https://vp.greshamsmith.com/vantagepoint/api/token
ERP_USERNAME=your-username
ERP_PASSWORD=your-password
ERP_GRANT_TYPE=password
ERP_INTEGRATED=N
ERP_DATABASE=Vantagepoint
ERP_CLIENT_ID=your-client-id
ERP_CLIENT_SECRET=your-client-secret
ERP_REFRESH_TOKEN=your-refresh-token
ERP_SCOPE=

# InvokeCustom stored procedure
ERP_STORED_PROCEDURE=your_stored_procedure_name

# Entra auth (server-side auth code flow)
AUTH_ENTRA_AUTHORITY=https://login.microsoftonline.com
AUTH_ENTRA_TENANT_ID=your-tenant-id-guid
AUTH_ENTRA_CLIENT_ID=your-client-id-guid
AUTH_ENTRA_CLIENT_SECRET=your-client-secret
AUTH_SCOPE=openid profile email

# Redirect URIs (single app registration, environment-specific)
AUTH_REDIRECT_URI_LOCAL=http://localhost:8000/auth/callback
AUTH_REDIRECT_URI_TEST=https://test.example.com/auth/callback
AUTH_REDIRECT_URI_PROD=https://app.example.com/auth/callback
AUTH_LOGOUT_REDIRECT_URI_LOCAL=http://localhost:8000/dev/admin
AUTH_LOGOUT_REDIRECT_URI_TEST=https://test.example.com
AUTH_LOGOUT_REDIRECT_URI_PROD=https://app.example.com
AUTH_LOGIN_SUCCESS_REDIRECT=/dev/admin
AUTH_SYNC_ENTRA_APP_ROLES=true

# Session settings
SESSION_SECRET=replace-with-long-random-secret
SESSION_COOKIE_NAME=qc_session
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
SESSION_MAX_AGE_SECONDS=28800

# Local bypass only (disabled by default)
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_TENANT_ID=local-tenant
AUTH_BYPASS_OBJECT_ID=local-object-id
AUTH_BYPASS_EMAIL=local.admin@example.com
AUTH_BYPASS_DISPLAY_NAME=Local Admin
AUTH_BYPASS_APP_USER_ID=00000000-0000-0000-0000-000000000001

# Comma-separated allowlist for bootstrap endpoint (/auth/bootstrap-admin)
AUTH_ADMIN_BOOTSTRAP_ALLOWLIST_OBJECT_IDS=
